text = input("Enter a string: ")
char_counts = {}
for char in text.lower():
    if char=="":
        continue
    if char in char_counts:
        char_counts[char]+=1
    else:
        char_counts[char]=1
print("duplicates character :")
for char,count in char_counts.items():
    if count > 1:
        print(f"'{char}': repeated {count}times")
